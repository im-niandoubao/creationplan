{
  "manifest_version": 3,
  "name": "摸鱼",
  "description": "工作页静止后显示娱乐小窗，鼠标或键盘活动时自动收起。",
  "version": "1.1.0",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "摸鱼",
    "default_popup": "options.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
